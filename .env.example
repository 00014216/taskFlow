# ─────────────────────────────────────────────────────────────
# CloudBlog Environment Variables
# ─────────────────────────────────────────────────────────────
#
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in the values below
# 3. NEVER commit the .env file to Git! It's in .gitignore.
#    The .env file contains secrets (passwords, keys).
#    The .env.example file is safe to commit - it's just a template.
# ─────────────────────────────────────────────────────────────

# ── Django Settings ────────────────────────────────────────
# A long random string used for security (signing cookies, tokens, etc.)
# Generate one here: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-very-long-random-secret-key-here-replace-this

# DEBUG: True for development, False for production
# NEVER set DEBUG=True on the live server!
DJANGO_DEBUG=True

# Which domain names Django will accept requests from
# Development: localhost,127.0.0.1
# Production: your-domain.com,your-server-ip
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL Database ────────────────────────────────────
# These must match the settings in docker-compose.yml
POSTGRES_DB=cloudblog_db
POSTGRES_USER=cloudblog_user
POSTGRES_PASSWORD=your-strong-database-password-here
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis Cache ────────────────────────────────────────────
# 'redis' is the Docker service name - containers find each other by name
# /1 means database number 1 (Redis has 16 databases, 0-15)
REDIS_URL=redis://redis:6379/1

# ── Docker Hub (for CI/CD pipeline) ───────────────────────
# Your Docker Hub username (used in deploy.yml and docker-compose.prod.yml)
DOCKERHUB_USERNAME=your-dockerhub-username
